# Example config/cloudflare.env for bin/fm-tunnel.sh.
# Copy to $FM_HOME/config/cloudflare.env (gitignored) and fill in real values.
# Every setting can also come from a same-named process environment variable,
# or from the matching CLI flag, which wins over both.

# Account-wide Cloudflare credentials.
# The API token needs these account-scoped permissions, plus the Read
# permission Cloudflare pairs with each Edit scope:
#   Account - Cloudflare Tunnel:Edit
#   Zone    - DNS:Edit
#   Account - Access: Apps and Policies:Edit
#   Account - Zone:Read / Zone - Zone:Read   (for zone lookup)
CLOUDFLARE_API_TOKEN=<scoped API token>
CLOUDFLARE_ACCOUNT_ID=<Cloudflare account id>

# One block per project. The key prefix is FM_TUNNEL_<PROJECT>_, where <PROJECT>
# is the project id passed on the command line, upper-cased with every character
# outside [A-Z0-9] folded to '_' (project "house-hunter" -> FM_TUNNEL_HOUSE_HUNTER_).
#
#   HOSTNAME       public hostname the project is served on
#   ZONE           the Cloudflare zone that hostname belongs to
#   SERVICE        the local origin fm-tunnel routes to (creation-time; --service)
#   ACCESS_EMAILS  comma-separated allow list for the Access one-time-PIN login
#                  (creation-time; --emails)
#
#   bin/fm-tunnel.sh up househunter
FM_TUNNEL_HOUSEHUNTER_HOSTNAME=househunter.example.com
FM_TUNNEL_HOUSEHUNTER_ZONE=example.com
FM_TUNNEL_HOUSEHUNTER_SERVICE=http://localhost:8765
FM_TUNNEL_HOUSEHUNTER_ACCESS_EMAILS=captain@example.com

# A second project, showing the folded prefix for a hyphenated project id.
#
#   bin/fm-tunnel.sh up reader-app
FM_TUNNEL_READER_APP_HOSTNAME=reader.example.com
FM_TUNNEL_READER_APP_ZONE=example.com
FM_TUNNEL_READER_APP_SERVICE=http://localhost:3000
FM_TUNNEL_READER_APP_ACCESS_EMAILS=captain@example.com,mate@example.com
